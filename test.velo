// Importujemy moduł FFI z LuaJIT
local ffi = require("ffi")

// 1. Definiujemy nagłówki C dla GLFW i OpenGL (tylko to, co niezbędne)
ffi.cdef[[
    // Definicje GLFW
    typedef void* GLFWwindow;
    int glfwInit(void);
    void glfwTerminate(void);
    GLFWwindow* glfwCreateWindow(int width, int height, const char* title, void* monitor, void* share);
    void glfwMakeContextCurrent(GLFWwindow* window);
    int glfwWindowShouldClose(GLFWwindow* window);
    void glfwSwapBuffers(GLFWwindow* window);
    void glfwPollEvents();
    void glfwWindowHint(int hint, int value);

    // Definicje OpenGL
    void glClearColor(float r, float g, float b, float a);
    void glClear(unsigned int mask);
    void glViewport(int x, int y, int width, int height);
    void glMatrixMode(unsigned int mode);
    void glLoadIdentity(void);
    void glRotatef(float angle, float x, float y, float z);
    void glBegin(unsigned int mode);
    void glEnd(void);
    void glColor3f(float r, float g, float b);
    void glVertex3f(float x, float y, float z);
    void glEnable(unsigned int cap);
]]

// 2. Ładujemy biblioteki systemowe (.so)
// Na Waylandzie GLFW automatycznie wybierze odpowiedni backend, jeśli skompilowano z jego obsługą
local glfw = ffi.load("libglfw.so.3")
local gl   = ffi.load("libGL.so.1")

// 3. Stałe z OpenGL i GLFW
local GL_COLOR_BUFFER_BIT   = 0x00004000
local GL_DEPTH_BUFFER_BIT   = 0x00000100
local GL_DEPTH_TEST         = 0x0B71
local GL_PROJECTION         = 0x1701
local GL_MODELVIEW          = 0x1700
local GL_QUADS              = 0x0007

// 4. Inicjalizacja GLFW
if glfw.glfwInit() == 0 {
    print("Nie udało się zainicjalizować GLFW!")
    return
}

// Tworzymy okno 800x600
local window = glfw.glfwCreateWindow(800, 600, "Velo + OpenGL Cube (Wayland)", nil, nil)
if window == nil {
    print("Nie udało się utworzyć okna GLFW!")
    glfw.glfwTerminate()
    return
}

glfw.glfwMakeContextCurrent(window)
gl.glEnable(GL_DEPTH_TEST)

// Ustawiamy tło na ciemnoszare
gl.glClearColor(0.1, 0.1, 0.1, 1.0)

// Prosta klasa do zarządzania naszą kostką w Velo
class CubeApp {
    function CubeApp() {
        self.angle = 0.0
    }

    function drawCube() {
        gl.glBegin(GL_QUADS)

        // Przednia ściana (Czerwona)
        gl.glColor3f(1.0, 0.0, 0.0)
        gl.glVertex3f(-0.5, -0.5,  0.5)
        gl.glVertex3f( 0.5, -0.5,  0.5)
        gl.glVertex3f( 0.5,  0.5,  0.5)
        gl.glVertex3f(-0.5,  0.5,  0.5)

        // Tylna ściana (Zielona)
        gl.glColor3f(0.0, 1.0, 0.0)
        gl.glVertex3f(-0.5, -0.5, -0.5)
        gl.glVertex3f(-0.5,  0.5, -0.5)
        gl.glVertex3f( 0.5,  0.5, -0.5)
        gl.glVertex3f( 0.5, -0.5, -0.5)

        // Górna ściana (Niebieska)
        gl.glColor3f(0.0, 0.0, 1.0)
        gl.glVertex3f(-0.5,  0.5, -0.5)
        gl.glVertex3f(-0.5,  0.5,  0.5)
        gl.glVertex3f( 0.5,  0.5,  0.5)
        gl.glVertex3f( 0.5,  0.5, -0.5)

        // Dolna ściana (Żółta)
        gl.glColor3f(1.0, 1.0, 0.0)
        gl.glVertex3f(-0.5, -0.5, -0.5)
        gl.glVertex3f( 0.5, -0.5, -0.5)
        gl.glVertex3f( 0.5, -0.5,  0.5)
        gl.glVertex3f(-0.5, -0.5,  0.5)

        // Prawa ściana (Fioletowa)
        gl.glColor3f(1.0, 0.0, 1.0)
        gl.glVertex3f( 0.5, -0.5, -0.5)
        gl.glVertex3f( 0.5,  0.5, -0.5)
        gl.glVertex3f( 0.5,  0.5,  0.5)
        gl.glVertex3f( 0.5, -0.5,  0.5)

        // Lewa ściana (Błękitna)
        gl.glColor3f(0.0, 1.0, 1.0)
        gl.glVertex3f(-0.5, -0.5, -0.5)
        gl.glVertex3f(-0.5, -0.5,  0.5)
        gl.glVertex3f(-0.5,  0.5,  0.5)
        gl.glVertex3f(-0.5,  0.5, -0.5)

        gl.glEnd()
    }

    function update() {
        self.angle += 0.5 // Obracamy kostkę przy każdej klatce
    }
}

// Tworzymy instancję aplikacji za pomocą Twojej składni OOP!
local app = new CubeApp()

// Główna pętla renderowania
while glfw.glfwWindowShouldClose(window) == 0 {
    gl.glClear(GL_COLOR_BUFFER_BIT + GL_DEPTH_BUFFER_BIT)

    // Reset macierzy i aplikacja rotacji
    gl.glMatrixMode(GL_MODELVIEW)
    gl.glLoadIdentity()
    gl.glRotatef(app.angle, 1.0, 1.0, 0.0) // Obrót w dwóch osiach

    // Renderowanie kostki
    app.drawCube()

    // Aktualizacja logiki (Twoje operatory compound add działają idealnie!)
    app.update()

    // Swap buffers i eventy
    glfw.glfwSwapBuffers(window)
    glfw.glfwPollEvents()
}

// Czyszczenie na koniec
glfw.glfwTerminate()
print("Aplikacja zamknięta pomyślnie!")
